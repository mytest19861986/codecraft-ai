# Copy to infra/.env.production on the VPS and replace every placeholder.
# Do not commit infra/.env.production.

# Next.js application
NEXT_PUBLIC_SITE_URL=https://codecraftai.ir
NODE_ENV=production
# PM2/host-level deployment port. Docker Compose uses WEB_PORT below for the host binding.
PORT=3001
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes
STUDENT_SESSION_SECRET=replace-with-at-least-32-random-bytes

# PostgreSQL container
POSTGRES_DB=codecraft
POSTGRES_USER=codecraft_app
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# Prisma connection string used by the web container.
# The hostname must be "postgres" because that is the Docker Compose service name.
# IMPORTANT: the password segment here must match POSTGRES_PASSWORD exactly.
DATABASE_URL=postgresql://codecraft_app:replace-with-a-long-random-database-password@postgres:5432/codecraft?schema=public

# Host port bindings. Keep localhost bindings when Nginx runs on the VPS host.
# Live VPS uses 3001 because Hami Card uses 3000 on the same server.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3001
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
